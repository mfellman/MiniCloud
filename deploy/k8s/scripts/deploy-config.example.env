# Kopieer naar deploy-config.local.env (niet in git) en vul aan.
#   cp deploy/k8s/scripts/deploy-config.example.env deploy/k8s/scripts/deploy-config.local.env
#
# === Verplicht ===
# Zelfde prefix als CI_REGISTRY_IMAGE (zonder slash aan het eind), bijv.:
#   registry.gitlab.com/mijn-groep/mijn-project
REGISTRY_PREFIX=registry.gitlab.com/example-group/example-project

# === Repository op deze machine ===
# Optioneel als je het script vanuit een volledige clone draait: wordt afgeleid.
# Op een kale controller verplicht, bv.:
#   REPO_ROOT=/opt/minicloud
#   GIT_REPO_URL=https://oauth2:glpat-xxx@gitlab.com/groep/minicloud.git

# Als REPO_ROOT nog geen .git heeft: clone-URL (HTTPS met token of SSH).
# Voorbeeld HTTPS + deploy token / PAT:
#   GIT_REPO_URL=https://oauth2:glpat-xxx@gitlab.com/groep/minicloud.git

# Branch die je uitrolt (clone + pull). Vaak develop of main.
GIT_REF=develop

# Shallow clone (--depth); zet op 0 voor volledige history (langzamer).
GIT_CLONE_DEPTH=1

# Bij TAG_MODE=latest standaard true: git fetch/checkout/pull vóór deploy.
# Zet op false om de huidige checkout ongemoeid te laten.
# UPDATE_GIT_BEFORE_DEPLOY=auto

# === Namespace ===
NAMESPACE=minicloud

# === Image tag ===
# latest     = registry-tag "latest" (CI pusht die standaard mee)
# explicit   = zet EXPLICIT_TAG hieronder
# git_short  = korte SHA van huidige git HEAD na sync (moet in registry bestaan)
TAG_MODE=latest
EXPLICIT_TAG=

# === Pull secret (private registry) ===
# Zet op false om geen secret aan te maken (bijv. publieke registry)
CREATE_PULL_SECRET=true
PULL_SECRET_NAME=gitlab-registry
GITLAB_REGISTRY_SERVER=registry.gitlab.com
# Deploy token, PAT of gebruikersnaam; wachtwoord/token hieronder
GITLAB_REGISTRY_USER=
GITLAB_REGISTRY_PASSWORD=

# === Na apply: imagePullSecrets op alle deployments zetten ===
PATCH_DEPLOYMENTS_PULL_SECRET=true

# Droge run (geen wijzigingen in cluster)
# DRY_RUN=false

# Toon gegenereerde kustomization en stop (debug)
# PRINT_ONLY=false
